        "jsCode": "// ── Helpers ──────────────────────────────────────────────\nconst unique = arr => [...new Set(arr.filter(Boolean).map(v => String(v).trim()))];\nconst toStr = arr => unique(arr).join(', ');\n\n// Safely decode percent-encoded characters in mailto: links (e.g. %40 -> @)\nconst decodeUriSafe = str => {\n  try {\n    return decodeURIComponent(str);\n  } catch {\n    return str;\n  }\n};\n\n// Filenames like \"logo@2x.png\" match the email shape but aren't emails.\n// We filter these out by checking the apparent TLD against known image/file extensions.\nconst NON_EMAIL_EXTENSIONS = new Set([\n  'png', 'jpg', 'jpeg', 'gif', 'webp', 'svg', 'ico', 'bmp', 'tiff'\n]);\n\nconst isLikelyRealEmail = email => {\n  const tld = email.split('.').pop().toLowerCase();\n  return !NON_EMAIL_EXTENSIONS.has(tld);\n};\n\n// ── Cloudflare Email Decoder ─────────────────────────────\nfunction decodeCfEmail(encoded) {\n  try {\n    const key = parseInt(encoded.substr(0, 2), 16);\n    let email = '';\n\n    for (let i = 2; i < encoded.length; i += 2) {\n      const charCode = parseInt(encoded.substr(i, 2), 16) ^ key;\n      email += String.fromCharCode(charCode);\n    }\n\n    return email;\n  } catch {\n    return null;\n  }\n}\n\n// ── Source HTML ──────────────────────────────────────────\nconst html =\n  $input.item.json.body ??\n  $input.item.json.data ??\n  '';\n\nif (!html) {\n  return {\n    json: {\n      ...$input.item.json,\n      emails: '',\n      phones: '',\n      linkedin: '',\n      facebook: '',\n      instagram: '',\n      twitter: '',\n      email_count: 0,\n      phone_count: 0,\n      _extracted: false\n    }\n  };\n}\n\n// ── EMAIL EXTRACTION ─────────────────────────────────────\n\n// Normal emails\nconst directEmails =\n  html.match(/[a-z0-9._%+\\-]+@[a-z0-9.\\-]+\\.[a-z]{2,}/gi) || [];\n\n// mailto: (decode %40 etc., and split multiple addresses inside one mailto link)\nconst mailtoEmails =\n  [...html.matchAll(/mailto:([^\"'?#\\s]+)/gi)]\n    .flatMap(m => decodeUriSafe(m[1]).split(','))\n    .map(e => e.trim());\n\n// Cloudflare protected emails\nconst cfMatches =\n  [...html.matchAll(/data-cfemail=\"([a-f0-9]+)\"/gi)];\n\nconst cloudflareEmails =\n  cfMatches\n    .map(m => decodeCfEmail(m[1]))\n    .filter(Boolean);\n\n// Merge all emails, lowercase, and drop image-filename false positives (e.g. logo@2x.png)\nconst emails = unique([\n  ...directEmails,\n  ...mailtoEmails,\n  ...cloudflareEmails\n])\n  .map(e => e.toLowerCase())\n  .filter(isLikelyRealEmail);\n\n// ── SOCIAL EXTRACTION ────────────────────────────────────\n\n// Normalize matched URLs (protocol, www, trailing slash) so trivial variants\n// of the same profile don't show up as separate-looking entries\nconst normalizeSocialUrl = url =>\n  url\n    .replace(/^http:/i, 'https:')\n    .replace(/^(https:\\/\\/)www\\./i, '$1')\n    .replace(/\\/+$/, '');\n\nconst linkedin = unique(\n  (html.match(\n    /https?:\\/\\/(?:www\\.)?linkedin\\.com\\/(?:in|company|pub)\\/[^\\s\"'<>?#]+/gi\n  ) || []).map(normalizeSocialUrl)\n);\n\nconst facebook = unique(\n  (html.match(\n    /https?:\\/\\/(?:www\\.)?facebook\\.com\\/[^\\s\"'<>?#]+/gi\n  ) || []).map(normalizeSocialUrl)\n);\n\nconst instagram = unique(\n  (html.match(\n    /https?:\\/\\/(?:www\\.)?instagram\\.com\\/[^\\s\"'<>?#]+/gi\n  ) || []).map(normalizeSocialUrl)\n);\n\nconst twitter = unique(\n  (html.match(\n    /https?:\\/\\/(?:www\\.)?(?:twitter|x)\\.com\\/[^\\s\"'<>?#]+/gi\n  ) || []).map(normalizeSocialUrl)\n);\n\n// ── PHONE EXTRACTION ─────────────────────────────────────\n\n// tel: links — a strong, low-noise signal most sites use for click-to-call numbers\nconst telLinks =\n  [...html.matchAll(/tel:([^\"'?#\\s]+)/gi)]\n    .map(m => m[1]);\n\n// Indian phones — now also catches numbers written with a space/hyphen between\n// the two 5-digit groups (e.g. \"98765 43210\", \"+91-98765-43210\"), and uses\n// boundaries so a 10-digit slice isn't pulled out of a longer, unrelated digit string\nconst indianRaw =\n  html.match(\n    /(?<!\\d)(?:\\+91[\\s\\-]?)?[6-9]\\d{4}[\\s\\-]?\\d{5}(?!\\d)/g\n  ) || [];\n\nconst normalizeIndianDigits = phone => {\n  const digits = phone.replace(/\\D/g, '');\n\n  if (digits.startsWith('91') && digits.length === 12) {\n    return digits.slice(2);\n  }\n\n  if (digits.length === 10) {\n    return digits;\n  }\n\n  return null;\n};\n\nconst indianPhones = [...indianRaw, ...telLinks]\n  .map(normalizeIndianDigits)\n  .filter(Boolean);\n\n// International phones\nconst intlRaw =\n  html.match(\n    /\\+\\d{1,3}[\\s\\-]?\\(?\\d{1,4}\\)?[\\s\\-]?\\d{1,4}[\\s\\-]?\\d{1,9}/g\n  ) || [];\n\nconst intlPhones = [...intlRaw, ...telLinks]\n  .map(phone => {\n    const digits = phone.replace(/\\D/g, '');\n\n    if (digits.length >= 7 && digits.length <= 15) {\n      return phone.trim();\n    }\n\n    return null;\n  })\n  .filter(Boolean);\n\n// Merge, then de-dupe by underlying digits so the same number formatted two\n// different ways (e.g. \"9876543210\" vs \"+91 98765 43210\") isn't reported twice\nconst seenDigits = new Set();\nconst phones = [];\n\nfor (const phone of [...indianPhones, ...intlPhones]) {\n  const digits = phone.replace(/\\D/g, '').replace(/^91(?=\\d{10}$)/, '');\n  if (!digits || seenDigits.has(digits)) continue;\n  seenDigits.add(digits);\n  phones.push(String(phone).trim());\n}\n\n// ── OUTPUT ───────────────────────────────────────────────\n\nreturn {\n  json: {\n    ...$input.item.json,\n\n    emails: toStr(emails),\n    phones: toStr(phones),\n\n    linkedin: toStr(linkedin),\n    facebook: toStr(facebook),\n    instagram: toStr(instagram),\n    twitter: toStr(twitter),\n\n    email_count: emails.length,\n    phone_count: unique(phones).length,\n\n    _extracted: true,\n    _extractedAt: new Date().toISOString()\n  }\n};"
