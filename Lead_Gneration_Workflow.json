      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const website = String($json.Website || '').trim();\nconst phone = String($json.Phone || '').trim();\n\nconst cleanPhone = phone.replace(/\\D/g, '');\n\nconst normalizedWebsite =\n  website && !/^https?:\\/\\//i.test(website)\n    ? `https://${website}`\n    : website;\n\nconst websiteLower = normalizedWebsite.toLowerCase();\n\nconst socialDomains = [\n  'instagram.com',\n  'facebook.com',\n  'fb.com',\n  'linkedin.com',\n  'youtube.com',\n  'youtu.be',\n  'twitter.com',\n  'x.com',\n  'wa.me',\n  'whatsapp.com',\n  't.me',\n  'telegram.me',\n  'pinterest.com',\n  'threads.net',\n  'tiktok.com'\n];\n\nconst isSocial = socialDomains.some(domain =>\n  websiteLower.includes(domain)\n);\n\nreturn {\n  ...$json,\n\n  // Cleaned fields\n  Website: normalizedWebsite,\n  Phone: cleanPhone,\n\n  // Flags\n  Has_Website: !!normalizedWebsite,\n  Has_Phone: !!cleanPhone,\n\n  // Website classification\n  isSocial,\n  website_type: isSocial ? 'social' : 'website',\n\n  // Lead quality\n  Lead_Status:\n    normalizedWebsite && cleanPhone\n      ? 'Complete'\n      : normalizedWebsite || cleanPhone\n      ? 'Partial'\n      : 'Incomplete',\n\n  // Category cleanup\n  Category_Text: Array.isArray($json.Category)\n    ? $json.Category.join(', ')\n    : ($json.Category || '')\n};"
      },
      "type": "n8n-nodes-base.code",
