        "jsCode": "const originalUrl = ($json.Website || '').trim();\n\nlet domain = '';\n\ntry {\n  domain = new URL(originalUrl).hostname;\n} catch {\n  domain = originalUrl\n    .replace(/^https?:\\/\\//, '')\n    .split('/')[0];\n}\n\nconst paths = [\n  '/contact',\n  '/contact-us',\n  '/contactus',\n  '/about',\n  '/about-us',\n  '/aboutus',\n  '/company',\n  '/support',\n  '/help'\n];\n\nconst urls = [\n  originalUrl, // crawl original URL first\n  ...paths.map(path => `https://${domain}${path}`)\n];\n\nreturn {\n  json: {\n    ...$json,\n    domain,\n    urls: [...new Set(urls)]\n  }\n};"
